# Environment variables for lattice development

# Optional bearer token for lattice server HTTP/WS auth
# When set, clients must include:
# - HTTP: Authorization: Bearer $LATTICE_SERVER_AUTH_TOKEN
# - WebSocket: ws://host:port/ws?token=$LATTICE_SERVER_AUTH_TOKEN (recommended for Expo)
# - or Sec-WebSocket-Protocol header with the token value
LATTICE_SERVER_AUTH_TOKEN=

# API Keys for AI providers
# Required for integration tests when TEST_INTEGRATION=1
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: Set to 1 to run integration tests
# Integration tests require API keys to be set
# TEST_INTEGRATION=1

# Telemetry (PostHog)
# These have defaults, override only if needed (e.g., for self-hosting)
# VITE_PUBLIC_POSTHOG_KEY=phc_vF1bLfiD5MXEJkxojjsmV5wgpLffp678yhJd3w9Sl4G
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── macOS Code Signing ───────────────────────────────────────────────────
# Developer ID Application certificate.
# Local builds: electron-builder auto-detects from Keychain (leave unset).
# CI builds: export .p12 from Keychain, base64-encode it.
# CSC_LINK=/path/to/DeveloperID_Application.p12
# CSC_KEY_PASSWORD=your-password

# ── Apple Notarization ───────────────────────────────────────────────────
# App Store Connect API key for notarization.
# Create at: https://appstoreconnect.apple.com/access/integrations/api
# Access level: "Developer" is sufficient.
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# ── Windows EV Code Signing (GCP Cloud KMS) ─────────────────────────────
# EV_KEYSTORE=
# EV_KEY=
# EV_CERTIFICATE_PATH=
# EV_TSA_URL=http://timestamp.digicert.com
# GCLOUD_ACCESS_TOKEN=
